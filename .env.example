# LLM API 配置（支持任意 OpenAI 兼容格式）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash

# 后端配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5001
DEBUG=false

# 数据存储路径
DATA_DIR=./data

# GraphRAG 配置
GRAPHRAG_LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
# 长期记忆使用的 Embedding 模型，必须与下面 EMBEDDING_BASE_URL（留空则为 LLM_BASE_URL）
# 指向的平台兼容，例如硅基流动用 BAAI/bge-m3，阿里 DashScope 用 text-embedding-v3
GRAPHRAG_EMBEDDING_MODEL=BAAI/bge-m3

# 长期记忆 Embedding 的服务商配置，留空则复用 LLM_API_KEY / LLM_BASE_URL
# 仅当 Embedding 模型和 Chat 模型分属不同服务商时才需要单独配置
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# 场景引擎默认配置
DEFAULT_MAX_TURNS=20
DEFAULT_SPEAKER_MODE=round_robin

# 记忆配置
SHORT_TERM_BUFFER_SIZE=20
MEMORY_TOP_K=5

# 日志级别
LOG_LEVEL=INFO
