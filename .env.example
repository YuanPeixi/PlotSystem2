# LLM API 配置（支持任意 OpenAI 兼容格式）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.siliconflow/v1
LLM_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash

# 后端配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5001
DEBUG=false

# 数据存储路径
DATA_DIR=./data

# GraphRAG 配置
GRAPHRAG_LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
GRAPHRAG_EMBEDDING_MODEL=text-embedding-v3 # BAAI/bge-m3

# 场景引擎默认配置
DEFAULT_MAX_TURNS=20
DEFAULT_SPEAKER_MODE=round_robin

# 记忆配置
SHORT_TERM_BUFFER_SIZE=20
MEMORY_TOP_K=5

# 日志级别
LOG_LEVEL=INFO
