# ============================================================
# PlotSystem 环境变量完整参考
# 字段名与 backend/config.py 的 Settings 一一对应（大小写不敏感）。
# 未在此文件中列出的变量不会被读取（pydantic-settings extra="ignore"）。
# ============================================================

# ---- LLM 基础配置（必填，支持任意 OpenAI 兼容格式 API）----
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.siliconflow.cn/v1
# 默认模型：以下三个"异构模型"留空时均回退到这里
LLM_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash

# ---- 异构模型（可选，留空则沿用 LLM_MODEL_NAME）----
# 三个智能体分别读取 settings.director_model / character_model / summary_model，
# 已在 backend/agents/{director,character,summary}_agent.py 中接入，走
# backend/utils/llm.py 的 chat()/chat_safe()，实际生效。
# 注意：AutoGen 集成路径（backend/agents/base_agent.py 的 make_model_client）
# 目前是未被 SceneEngine 调用的 dead code，仅 CharacterAgent.get_autogen_agent()
# 会用到，详见该函数上的注释。
# 导演：建议长上下文、指令遵循强的模型，如 DeepSeek-V4-Pro / Qwen3-235B
LLM_MODEL_DIRECTOR=deepseek-ai/DeepSeek-V4-Flash
# 角色：建议扮演沉浸感强的模型，如 DeepSeek-V4-Flash / GLM-4
LLM_MODEL_CHARACTER=deepseek-ai/DeepSeek-V4-Flash
# 总结：建议写作风格好的模型，如 DeepSeek-V3 / Qwen3-32B
LLM_MODEL_SUMMARY=deepseek-ai/DeepSeek-V4-Flash

# ---- 后端服务配置 ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5001
# 调试模式：开启后 FastAPI 会输出更详细的日志/报错堆栈，生产环境应为 false
DEBUG=false

# ---- 数据存储路径 ----
# 所有项目数据（种子文本/GraphRAG产物/Kuzu图库/ChromaDB/快照）的根目录
DATA_DIR=./data

# ---- GraphRAG 配置 ----
# [已弃用/未生效] 历史遗留字段，代码中未被任何模块读取（GraphRAG 相关调用
# 统一走 LLM_MODEL_NAME）。暂时保留字段以兼容旧 .env，不建议依赖它生效。
GRAPHRAG_LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
# 长期记忆使用的 Embedding 模型。真正生效（backend/memory/embeddings.py），
# 必须与下面 EMBEDDING_BASE_URL（留空则为 LLM_BASE_URL）指向的平台兼容，
# 例如硅基流动用 BAAI/bge-m3，阿里 DashScope 用 text-embedding-v3。
# 切换该模型后旧的 data/projects/*/chroma_db/ 目录需要清空重建（向量维度/
# 语义空间不兼容），详见 docs/fix-tickets/02-embedding-remote.md。
GRAPHRAG_EMBEDDING_MODEL=BAAI/bge-m3

# 长期记忆 Embedding 的服务商配置，留空则复用 LLM_API_KEY / LLM_BASE_URL。
# 仅当 Embedding 模型和 Chat 模型分属不同服务商时才需要单独配置。
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# ---- 场景引擎默认配置 ----
DEFAULT_MAX_TURNS=20
# round_robin（默认，轮流发言）| random（随机，仅测试用）
# | selector（LLM 选择下一发言者，当前为占位实现，完整版见
#   docs/fix-tickets/11-selector-and-world-interaction.md）
DEFAULT_SPEAKER_MODE=round_robin

# ---- 记忆系统配置 ----
# 短期记忆缓冲区最大轮次，超过后触发向长期记忆（ChromaDB）固化
SHORT_TERM_BUFFER_SIZE=20
# 长期记忆检索（RAG）每次返回的条数
MEMORY_TOP_K=5

# ---- 日志配置 ----
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
